<?xml version="1.0" encoding="utf-8"?>
<mujoco model="xmlrobot">
	<compiler/>
	<option gravity="0 0 0"/>
	<size nconmax="500" njmax="1000"/>
	<custom/>
	<default>
		<joint armature="1" damping="1" limited="true"/>
		<geom conaffinity="0" condim="3" margin="0.01" rgba="0.8 0.6 0.4 1"/>
	</default>
	<asset>
		<texture builtin="gradient" height="100" rgb1="1 1 1" rgb2="0 0 0" type="skybox" width="100"/>
		<texture builtin="flat" height="1278" mark="cross" markrgb="1 1 1" name="texgeom" random="0.01" rgb1="0.8 0.6 0.4" rgb2="0.8 0.6 0.4" type="cube" width="127"/>
		<texture builtin="checker" height="100" name="texplane" rgb1="0 0 0" rgb2="0.8 0.8 0.8" type="2d" width="100"/>
		<material name="MatPlane" reflectance="0.5" shininess="1" specular="1" texrepeat="60 60" texture="texplane"/>
		<material name="geom" texture="texgeom" texuniform="true"/>
	</asset>
	<worldbody>
		<light cutoff="100" diffuse="1 1 1" dir="0 0 -1.3" directional="true" exponent="1" pos="0 0 1.3" specular="0.1 0.1 0.1"/>
		<geom conaffinity="1" condim="3" material="MatPlane" name="floor" pos="0 0 0" rgba="0.8 0.9 0.8 1" size="40 40 40" type="plane"/>
		<body name="root" pos="0 0 2" euler="0 0 0">
			<geom name="geomroot" pos="0 0 2" size="0.0005" type="sphere"/>
			<body name="body1" pos="0 0 0" euler="0 90 0">
				<geom fromto="0 0 0 0.1 0 0" name="geombody1" pos="0 0 0" size="0.5" type="cylinder"/>
				<joint axis="1 0 0" name="joint_joint1" pos="0 0 0" range="-45 45" type="hinge"/>
				<body name="limbmount1" pos="0 0.5 0" euler="0 0 0">
					<geom fromto="0 0 0 0.025 0 0" name="geomlimbmount1" size="0.025" type="capsule"/>
					<joint axis="1 0 0" name="joint_joint2" pos="0 0 0" range="-45 45" type="hinge"/>
				</body>
			</body>
		</body>
	</worldbody>
	<actuator>
		<motor ctrllimited="true" ctrlrange="-1 1" joint="joint_joint1"/>
		<motor ctrllimited="true" ctrlrange="-1 1" joint="joint_joint2"/>
	</actuator>
</mujoco>